# Optional: webhook for contact form submissions (Slack, Zapier, Make, etc.)
CONTACT_WEBHOOK_URL=

# Optional: webhook for newsletter signups (falls back to FORM_WEBHOOK_URL)
NEWSLETTER_WEBHOOK_URL=

# Optional: shared webhook for all form submissions
FORM_WEBHOOK_URL=

# Optional: Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Optional: Google Search Console verification code
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Production site URL (used for sitemap, canonical URLs, OG tags)
NEXT_PUBLIC_SITE_URL=https://gieo.agency
